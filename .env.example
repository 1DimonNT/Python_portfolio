# .env.example
SELENOID_URL=selenoid.autotests.cloud/wd/hub
SELENOID_USER=your_username
SELENOID_PASSWORD=your_password

# URL тестовых приложений
BASE_URL=https://www.saucedemo.com
API_BASE_URL=https://reqres.in/api
SAUCEDEMO_URL=https://www.saucedemo.com
JSONPLACEHOLDER_URL=https://jsonplaceholder.typicode.com

# Настройки браузера
BROWSER=chrome
BROWSER_VERSION=128.0
WINDOW_SIZE=1920,1080
TIMEOUT=30

# Telegram (опционально)
TELEGRAM_TOKEN=
TELEGRAM_CHAT_ID=

# Allure
ALLURE_MAX_ATTACHMENT_SIZE=5000

# Selenoid видео
SELENOID_VIDEO_URL=https://selenoid.autotests.cloud/video
VIDEO_DOWNLOAD_TIMEOUT=30
SELENOID_VIDEO_ENABLED=true
