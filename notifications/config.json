{
  "base": {
    "project": "${JOB_BASE_NAME}",
    "environment": "Jenkins",
    "comment": "Сборка #${BUILD_NUMBER}",
    "reportLink": "${BUILD_URL}",
    "language": "ru",
    "allureFolder": "allure-report",
    "enableChart": true
  },
  "telegram": {
    "token": "${TELEGRAM_BOT_TOKEN}",  // ✅ через переменную окружения
    "chat": "${TELEGRAM_CHAT_ID}",
    "replyTo": ""
  }
}